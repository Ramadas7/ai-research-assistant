# Copy this file to .env and adjust if needed. Defaults work for a standard local Ollama install.

SECRET_KEY=change-this-in-production
OLLAMA_HOST=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.2
OLLAMA_VISION_MODEL=llama3.2-vision

# Set to "false" to skip figure/graph understanding entirely (faster uploads,
# useful if you don't want to pull the ~8GB vision model).
ENABLE_VISION=true
